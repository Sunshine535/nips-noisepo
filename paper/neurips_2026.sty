% neurips_2026.sty - Minimal NeurIPS 2026 style
% Based on standard NeurIPS formatting guidelines
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2026}[2026/01/01 NeurIPS 2026 style]

\newif\if@preprint
\newif\if@final
\newif\if@nonatbib
\DeclareOption{preprint}{\@preprinttrue}
\DeclareOption{final}{\@finaltrue}
\DeclareOption{nonatbib}{\@nonatbibtrue}
\DeclareOption*{\PackageWarning{neurips_2026}{Unknown option: \CurrentOption}}
\ProcessOptions\relax

% Page layout matching NeurIPS
\RequirePackage[verbose=true,letterpaper]{geometry}
\AtBeginDocument{
  \newgeometry{
    textheight=9in,
    textwidth=5.5in,
    top=1in,
    headheight=12pt,
    headsep=25pt,
    footskip=30pt
  }
}

% Fonts
\RequirePackage{times}

% Natbib for citations
\if@nonatbib\else
  \RequirePackage[round,sort&compress,numbers]{natbib}
\fi

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}

% Paragraph spacing
\setlength{\parskip}{0.5ex plus 0.2ex minus 0.1ex}

% Abstract
\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.5ex}%
  \begin{quote}%
}{%
  \end{quote}%
}

% Title
\def\@maketitle{%
  \newpage\null
  \vskip 2em
  \begin{center}%
    {\LARGE\bfseries \@title \par}%
    \vskip 1.5em%
    {\large \@author \par}%
    \vskip 1em%
    {\large \@date}%
  \end{center}%
  \par\vskip 1.5em%
}

% Preprint notice
\if@preprint
  \RequirePackage{fancyhdr}
  \pagestyle{fancy}
  \fancyhf{}
  \fancyhead[C]{\small Preprint. Under review.}
  \fancyfoot[C]{\thepage}
  \renewcommand{\headrulewidth}{0pt}
\fi

\endinput
